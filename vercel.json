{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!api/|@vite|@id|@fs|@react-refresh|src/|node_modules/|assets/|bags/|data/|placeholder/|favicon|icon|manifest|robots|sitemap|.*\\.[a-zA-Z0-9]+$).*)",
      "destination": "/index.html"
    }
  ]
}
